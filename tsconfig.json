{
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "target": "ES2020",
    "module": "commonjs",
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "references": [
    { "path": "./backend" }
  ],
  "include": ["backend/**/*"],
  "exclude": ["node_modules", "backend/dist"]
}
